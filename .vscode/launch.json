{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(lldb) Launch HomeTUI",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/tui_example",
            "args": [],
            "cwd": "${workspaceFolder}",
            "terminal": "integrated"
        },
        {
            "name": "(lldb) Attach to HomeTUI",
            "type": "lldb",
            "request": "attach",
            "program": "${workspaceFolder}/tui_example",
            "pid": "${command:pickProcess}"
        }
    ]
}
